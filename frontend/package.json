{
  "name": "caps-frontend",
  "version": "1.0.0",
  "description": "Frontend Expo React App with Tailwind CSS",
  "main": "index.js",
  "scripts": {
    "dev": "expo start --lan",
    "start": "expo start --lan",
    "start:lan": "expo start --lan",
    "start:tunnel": "expo start --tunnel",
    "android": "expo start --lan --android",
    "ios": "expo start --lan --ios",
    "android:tunnel": "expo start --tunnel --android",
    "ios:tunnel": "expo start --tunnel --ios",
    "verify:camera-discovery": "node ./scripts/verify-camera-discovery.js",
    "web": "expo start --web",
    "eject": "expo eject"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/masked-view": "^0.1.11",
    "@react-navigation/native": "~6.1.18",
    "@react-navigation/native-stack": "~6.9.26",
    "axios": "^1.6.0",
    "expo": "~54.0.0",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "react": "^19.1.0",
    "react-dom": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@expo/ngrok": "^4.1.3",
    "babel-preset-expo": "~54.0.10",
    "nativewind": "^2.0.11",
    "tailwindcss": "^3.4.19"
  }
}
